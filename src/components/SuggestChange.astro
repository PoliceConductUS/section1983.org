---
interface Props {
  pagePath: string;
}

const { pagePath } = Astro.props;
---

<div class="mt-10 pt-6 border-t border-slate-200 text-sm text-slate">
  <p>
    Have corrections or want to suggest a change?
    <button
      type="button"
      data-sentry-feedback-trigger
      data-sentry-feedback-page={pagePath}
      data-sentry-feedback-surface="suggest-change"
      class="cursor-pointer font-semibold text-navy hover:text-gold"
    >
      Let us know
    </button>
  </p>
</div>
