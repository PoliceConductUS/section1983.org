---
import Base from "./Base.astro";
import DisqusComments from "../components/DisqusComments.astro";
import ShareButtons from "../components/ShareButtons.astro";

interface Props {
  title: string;
  description?: string;
  canonicalUrl: string;
  pubDate?: Date | null;
  author?: string;
  tags?: string[];
  wordCount?: number;
  updatedDate?: Date;
  ogImage?: string;
  relatedCases?: { href: string; label: string; description: string }[];
  relatedTermsAndConcepts?: {
    href: string;
    label: string;
    description: string;
  }[];
  relatedProcess?: { href: string; label: string; description: string }[];
}

const {
  title,
  description,
  canonicalUrl,
  pubDate,
  author,
  tags,
  wordCount,
  updatedDate,
  ogImage,
  relatedCases = [],
  relatedTermsAndConcepts = [],
  relatedProcess = [],
} = Astro.props;

const formattedDate = pubDate
  ? new Intl.DateTimeFormat("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    }).format(pubDate)
  : null;
const imageUrl = new URL(
  ogImage || "/og-image.png",
  "https://www.section1983.org",
).toString();
const readingMinutes = wordCount
  ? Math.max(1, Math.round(wordCount / 225))
  : null;
const readingTimeLabel = readingMinutes ? `${readingMinutes} min read` : null;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: description,
  author: author
    ? {
        "@type": "Person",
        name: author,
      }
    : {
        "@type": "Organization",
        name: "Institute for Police Conduct, Inc.",
        url: "https://policeconduct.org",
      },
  image: imageUrl,
  isAccessibleForFree: true,
  keywords: tags?.join(", "),
  mainEntityOfPage: canonicalUrl,
  publisher: {
    "@type": "Organization",
    name: "Institute for Police Conduct, Inc.",
    url: "https://policeconduct.org",
  },
  url: canonicalUrl,
  ...(pubDate && { datePublished: pubDate.toISOString() }),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  ...(wordCount ? { wordCount } : {}),
  ...(readingMinutes ? { timeRequired: `PT${readingMinutes}M` } : {}),
};
---

<Base
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  ogType="article"
  ogImageAlt={title}
  structuredData={structuredData}
>
  <ShareButtons title={title} description={description} url={canonicalUrl} />

  <slot name="breadcrumbs" />
  <article>
    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-navy leading-tight mb-4">
        {title}
      </h1>
      <div class="flex flex-wrap items-center gap-4 text-sm text-slate">
        {
          formattedDate && (
            <time datetime={pubDate?.toISOString()}>{formattedDate}</time>
          )
        }
        {readingTimeLabel && <span>{readingTimeLabel}</span>}
        {author && <span>by {author}</span>}
      </div>
      {
        tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-3">
            {tags.map((tag) => (
              <span class="bg-navy/10 text-navy text-xs px-2 py-1 rounded">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </header>

    <div class="prose">
      <slot />
    </div>

    {
      (relatedTermsAndConcepts.length > 0 ||
        relatedCases.length > 0 ||
        relatedProcess.length > 0) && (
        <aside class="mt-12 border-t border-slate-200 pt-8 not-prose">
          <h2 class="text-xl font-bold text-navy mb-4">Keep Reading</h2>
          <div class="grid gap-6 md:grid-cols-3">
            {relatedTermsAndConcepts.length > 0 && (
              <section>
                <h3 class="text-sm font-bold uppercase tracking-wide text-navy mb-3">
                  Terms and Concepts
                </h3>
                <div class="space-y-3">
                  {relatedTermsAndConcepts.map((entry) => (
                    <a
                      href={entry.href}
                      class="block rounded border border-slate-200 bg-white p-4 hover:border-gold hover:shadow-sm transition-all"
                    >
                      <p class="font-semibold text-navy">{entry.label}</p>
                      <p class="mt-1 text-sm text-slate">{entry.description}</p>
                    </a>
                  ))}
                </div>
              </section>
            )}
            {relatedCases.length > 0 && (
              <section>
                <h3 class="text-sm font-bold uppercase tracking-wide text-navy mb-3">
                  Relevant Cases
                </h3>
                <div class="space-y-3">
                  {relatedCases.map((entry) => (
                    <a
                      href={entry.href}
                      class="block rounded border border-slate-200 bg-white p-4 hover:border-gold hover:shadow-sm transition-all"
                    >
                      <p class="font-semibold text-navy">{entry.label}</p>
                      <p class="mt-1 text-sm text-slate">{entry.description}</p>
                    </a>
                  ))}
                </div>
              </section>
            )}
            {relatedProcess.length > 0 && (
              <section>
                <h3 class="text-sm font-bold uppercase tracking-wide text-navy mb-3">
                  Process Stages
                </h3>
                <div class="space-y-3">
                  {relatedProcess.map((entry) => (
                    <a
                      href={entry.href}
                      class="block rounded border border-slate-200 bg-white p-4 hover:border-gold hover:shadow-sm transition-all"
                    >
                      <p class="font-semibold text-navy">{entry.label}</p>
                      <p class="mt-1 text-sm text-slate">{entry.description}</p>
                    </a>
                  ))}
                </div>
              </section>
            )}
          </div>
        </aside>
      )
    }

    <slot name="pagination" />
  </article>

  <DisqusComments
    pageUrl={canonicalUrl}
    disqusIdentifier={`article-${Astro.params.slug}`}
  />
</Base>
