---
import Base from "./Base.astro";

interface Props {
  title: string;
  description: string;
  order: number;
  movant: string;
  respondent: string;
  slug: string;
  canonicalUrl: string;
  updatedDate?: Date;
  relatedArticles?: { href: string; label: string; description: string }[];
}

const {
  title,
  description,
  order,
  movant,
  respondent,
  slug,
  canonicalUrl,
  updatedDate,
  relatedArticles = [],
} = Astro.props;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "HowToStep",
  name: title,
  text: description,
  position: order,
  url: canonicalUrl,
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
};
---

<Base
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogType="article"
  ogImageAlt={`Step ${order}: ${title}`}
  structuredData={structuredData}
>
  <slot name="breadcrumbs" />

  <article>
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-3">
        <span class="bg-navy text-white text-sm font-bold px-3 py-1 rounded"
          >Step {order}</span
        >
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-navy leading-tight mb-4">
        {title}
      </h1>
      <p class="text-lg text-slate mb-4">{description}</p>
      <div class="flex gap-6 text-sm">
        <div>
          <strong class="text-navy">Who moves:</strong>
          <span class="text-slate">{movant}</span>
        </div>
        <div>
          <strong class="text-navy">Who responds:</strong>
          <span class="text-slate">{respondent}</span>
        </div>
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>

    {
      relatedArticles.length > 0 && (
        <aside class="mt-12 border-t border-slate-200 pt-8">
          <h2 class="text-xl font-bold text-navy mb-4">
            Articles About This Stage
          </h2>
          <div class="grid gap-4 md:grid-cols-2">
            {relatedArticles.map((article) => (
              <a
                href={article.href}
                class="block rounded border border-slate-200 bg-white p-4 hover:border-gold hover:shadow-sm transition-all"
              >
                <p class="font-semibold text-navy">{article.label}</p>
                <p class="mt-1 text-sm text-slate">{article.description}</p>
              </a>
            ))}
          </div>
        </aside>
      )
    }

    <slot name="pagination" />
  </article>
</Base>
