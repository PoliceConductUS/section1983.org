---
import Base from "./Base.astro";

interface Props {
  title: string;
  description: string;
  order: number;
  movant: string;
  respondent: string;
  slug: string;
  canonicalUrl: string;
}

const { title, description, order, movant, respondent, slug, canonicalUrl } =
  Astro.props;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "HowToStep",
  name: title,
  text: description,
  position: order,
  url: canonicalUrl,
};
---

<Base
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogType="article"
  ogImageAlt={`Step ${order}: ${title}`}
  structuredData={structuredData}
>
  <slot name="breadcrumbs" />

  <article>
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-3">
        <span class="bg-navy text-white text-sm font-bold px-3 py-1 rounded"
          >Step {order}</span
        >
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-navy leading-tight mb-4">
        {title}
      </h1>
      <p class="text-lg text-slate mb-4">{description}</p>
      <div class="flex gap-6 text-sm">
        <div>
          <strong class="text-navy">Who moves:</strong>
          <span class="text-slate">{movant}</span>
        </div>
        <div>
          <strong class="text-navy">Who responds:</strong>
          <span class="text-slate">{respondent}</span>
        </div>
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>

    <slot name="pagination" />
  </article>
</Base>
