---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ArticleCard from "../../components/ArticleCard.astro";

const allArticles = await getCollection("articles");
const published = allArticles
  .filter((a) => !a.data.draft)
  .sort((a, b) => {
    const dateA = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
    const dateB = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
    return dateA - dateB;
  });

const canonicalUrl = "https://www.section1983.org/articles/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Section 1983 Articles",
  description:
    "Plain-language articles about Section 1983 litigation, qualified immunity, pleading standards, damages, and the practical economics of civil rights cases.",
  url: canonicalUrl,
  mainEntity: {
    "@type": "ItemList",
    itemListElement: published.map((article, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: `https://www.section1983.org/articles/${article.id}/`,
      name: article.data.title,
    })),
  },
};
---

<Base
  title="Section 1983 Articles"
  description="Plain-language articles on Section 1983 claims, qualified immunity, pleading standards, damages, and how federal civil rights cases actually work."
  canonicalUrl={canonicalUrl}
  structuredData={structuredData}
>
  <Breadcrumbs crumbs={[{ label: "Home", href: "/" }, { label: "Articles" }]} />

  <h1 class="text-3xl font-bold text-navy mb-8">Articles</h1>
  <p class="text-sm text-slate-600 mb-8">
    Need background before diving in? Use the <a
      href="/terms-and-concepts"
      class="text-navy underline decoration-gold decoration-2 hover:text-gold"
      >Terms and Concepts</a
    > for legal terms and the <a
      href="/process"
      class="text-navy underline decoration-gold decoration-2 hover:text-gold"
      >process guide</a
    > for the sequence of a federal case.
  </p>
  <p class="text-sm text-slate-600 mb-8">
    Read the articles in order from oldest to newest.
  </p>
  <div class="space-y-6">
    {
      published.map((article) => (
        <ArticleCard article={article} headingLevel="h2" />
      ))
    }
  </div>
</Base>
