---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const entries = await getCollection("primer");

// Group by category
const grouped = entries.reduce(
  (acc, entry) => {
    const cat = entry.data.category;
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(entry);
    return acc;
  },
  {} as Record<string, typeof entries>,
);

// Sort entries within each category alphabetically
for (const cat of Object.keys(grouped)) {
  grouped[cat].sort((a, b) => a.data.term.localeCompare(b.data.term));
}

const categoryOrder = [
  "constitutional-law",
  "qualified-immunity",
  "statute",
  "doctrine",
  "procedure",
  "evidence",
  "remedies",
];

const categoryLabels: Record<string, string> = {
  "constitutional-law": "Constitutional Law",
  procedure: "Procedure",
  evidence: "Evidence",
  remedies: "Remedies",
  "qualified-immunity": "Qualified Immunity",
  statute: "Statute",
  doctrine: "Doctrine",
};

const canonicalUrl = "https://www.section1983.org/primer/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Section 1983 Pro Se Primer",
  description:
    "A plain-English primer explaining the legal terms, doctrines, rules, and remedies that appear in Section 1983 federal civil rights cases.",
  url: canonicalUrl,
  mainEntity: {
    "@type": "ItemList",
    itemListElement: [...entries]
      .sort((a, b) => a.data.term.localeCompare(b.data.term))
      .map((entry, index) => ({
        "@type": "ListItem",
        position: index + 1,
        url: `https://www.section1983.org/primer/${entry.id}/`,
        name: entry.data.term,
      })),
  },
};
---

<Base
  title="Section 1983 Pro Se Primer"
  description="Plain-English explanations of the legal terms, doctrines, and procedural rules that come up in Section 1983 civil rights litigation."
  canonicalUrl={canonicalUrl}
  structuredData={structuredData}
>
  <h1 class="text-3xl font-bold text-navy mb-4">Pro Se Primer</h1>
  <p class="text-lg text-slate-600 mb-10">
    The legal terms you're most likely to encounter in a § 1983 case, explained
    like you're a human being — not a law student. Click any term to learn what
    it means, why it matters, and how courts actually use it.
  </p>
  <p class="text-sm text-slate-600 mb-10">
    New here? Start with the <a
      href="/process"
      class="text-navy underline decoration-gold decoration-2 hover:text-gold"
      >legal process guide</a
    >, then come back here when a motion, doctrine, or damages rule needs translation.
  </p>

  {
    categoryOrder
      .filter((cat) => grouped[cat])
      .map((cat) => (
        <section class="mb-10">
          <h2 class="text-xl font-bold text-navy mb-4 border-b border-slate-200 pb-2">
            {categoryLabels[cat]}
          </h2>
          <div class="grid gap-3">
            {grouped[cat].map((entry) => (
              <a
                href={`/primer/${entry.id}`}
                class="block p-4 bg-white rounded border border-slate-200 hover:border-gold hover:shadow-sm transition-all"
              >
                <span class="font-semibold text-navy">{entry.data.term}</span>
                <span class="text-slate-500 ml-2 text-sm">
                  {entry.data.description}
                </span>
              </a>
            ))}
          </div>
        </section>
      ))
  }

  {
    entries.length === 0 && (
      <p class="text-slate-500 italic">
        Primer entries are being written. Check back soon.
      </p>
    )
  }
</Base>
