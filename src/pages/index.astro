---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import ArticleCard from "../components/ArticleCard.astro";

const allArticles = await getCollection("articles");
const articles = allArticles
  .filter(({ data }) => !data.draft)
  .sort((a, b) => {
    const dateA = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
    const dateB = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
    return dateA - dateB;
  });

const cases = await getCollection("cases");
const termsAndConcepts = await getCollection("termsAndConcepts");
const process = await getCollection("process");
const staticPages = [
  "/",
  "/about/",
  "/about/section-1983/",
  "/accessibility/",
  "/articles/",
  "/cases/",
  "/get-involved/",
  "/legal-notice/",
  "/process/",
  "/search/",
  "/sitemap/",
  "/terms/",
  "/terms-and-concepts/",
];

const contentPages =
  articles.length + cases.length + termsAndConcepts.length + process.length;
const totalPages = contentPages + staticPages.length;

// Estimate reading time from content body lengths (~5 chars/word, ~250 wpm)
const allContent = [...articles, ...cases, ...termsAndConcepts, ...process];
const totalChars = allContent.reduce(
  (sum, entry) => sum + (entry.body?.length || 0),
  0,
);
const totalWords = Math.round(totalChars / 5);
const readingHours = Math.round(totalWords / 250 / 60);

const uniqueCourts = new Set(cases.map((c) => c.data.court)).size;
const canonicalUrl = "https://www.section1983.org/";
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "section1983.org",
    url: canonicalUrl,
    description:
      "A free, independent guide to Section 1983 litigation, case law, federal procedure, and police accountability.",
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Institute for Police Conduct, Inc.",
    url: "https://policeconduct.org",
  },
];
---

<Base
  title="Section 1983 Guide to Police Accountability"
  canonicalUrl={canonicalUrl}
  structuredData={structuredData}
>
  <section class="mb-16">
    <p class="text-sm font-semibold text-gold uppercase tracking-wide mb-3">
      A project of the Institute for Police Conduct, Inc.
    </p>
    <h1 class="text-4xl md:text-5xl font-bold text-navy leading-tight mb-6">
      Your free guide to holding<br />
      <span class="text-gold">police accountable in federal court.</span>
    </h1>
    <p class="text-lg text-slate max-w-2xl leading-relaxed mb-4">
      When police violate your constitutional rights, federal law gives you the
      right to sue. This site explains how — in plain language, with real cases,
      for people representing themselves.
    </p>
    <p class="text-base text-slate max-w-2xl leading-relaxed mb-8">
      We are <strong class="text-navy">completely independent</strong> of police and
      government. No sponsors. No agenda. Just the law, explained honestly.
    </p>
    <div class="flex gap-4 flex-wrap">
      <a
        href="/articles"
        class="bg-navy text-white px-6 py-3 rounded font-semibold hover:bg-navy-light transition-colors"
      >
        Read Articles
      </a>
      <a
        href="/terms-and-concepts"
        class="border-2 border-navy text-navy px-6 py-3 rounded font-semibold hover:bg-navy hover:text-white transition-colors"
      >
        Terms and Concepts
      </a>
      <a
        href="/process"
        class="border-2 border-navy text-navy px-6 py-3 rounded font-semibold hover:bg-navy hover:text-white transition-colors"
      >
        Understand the Process
      </a>
      <a
        href="https://policeconduct.org/report/new"
        class="border-2 border-gold text-navy px-6 py-3 rounded font-semibold hover:bg-gold hover:text-white transition-colors"
        target="_blank"
        rel="noopener"
      >
        Report an Incident ↗
      </a>
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-2xl font-bold text-navy mb-3 border-b-2 border-gold pb-2">
      What Is On The Site Right Now
    </h2>
    <p class="text-sm text-slate mb-6 max-w-3xl">
      These numbers show what is live on the public site right now: articles to
      train you, case summaries to show how courts rule, terms and concepts
      entries to translate legal language, and process guides to walk you
      through a federal case step by step. The total page count below also
      includes the home page and the main section pages.
    </p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="text-center p-6 bg-white rounded-lg shadow-sm">
        <p class="text-3xl font-bold text-navy">{cases.length}</p>
        <p class="text-sm text-slate mt-1">Case Summaries</p>
      </div>
      <div class="text-center p-6 bg-white rounded-lg shadow-sm">
        <p class="text-3xl font-bold text-navy">{termsAndConcepts.length}</p>
        <p class="text-sm text-slate mt-1">Terms and Concepts</p>
      </div>
      <div class="text-center p-6 bg-white rounded-lg shadow-sm">
        <p class="text-3xl font-bold text-navy">{process.length}</p>
        <p class="text-sm text-slate mt-1">Process Guides</p>
      </div>
      <div class="text-center p-6 bg-white rounded-lg shadow-sm">
        <p class="text-3xl font-bold text-navy">
          {articles.length}
        </p>
        <p class="text-sm text-slate mt-1">Articles</p>
      </div>
    </div>
    <p class="text-center text-sm text-slate mt-4">
      {totalPages} published pages · {uniqueCourts} courts cited · about{" "}
      {readingHours} hours of reading · free to use
    </p>
  </section>

  <section>
    <h2 class="text-2xl font-bold text-navy mb-3 border-b-2 border-gold pb-2">
      Articles
    </h2>
    <p class="text-sm text-slate mb-6">
      Read the articles in order from oldest to newest.
    </p>
    <div class="space-y-6">
      {
        articles
          .slice(0, 5)
          .map((article) => <ArticleCard article={article} headingLevel="h3" />)
      }
    </div>
    <p class="text-sm text-slate mt-6">
      Want more articles? Browse all <a
        href="/articles"
        class="text-navy underline decoration-gold decoration-2 hover:text-gold"
      >
        Section 1983 articles
      </a>.
    </p>
  </section>
</Base>
